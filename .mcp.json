{
  "mcpServers": {
    "ludolph-channel": {
      "type": "stdio",
      "command": "python3",
      "args": ["~/.ludolph/mcp/mcp_server.py"],
      "env": {
        "VAULT_PATH": "~/vault",
        "PI_HOST": "pi.local",
        "PI_CHANNEL_PORT": "8202",
        "CHANNEL_AUTH_TOKEN": "your-token-here"
      }
    }
  }
}
